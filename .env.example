# MongoDB Atlas (required for RSVP API + admin table)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/ari-bm?retryWrites=true&w=majority

# SendGrid (required for RSVP notification emails)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# RSVP email — who receives submissions and the From header SendGrid uses
RSVP_NOTIFY_EMAIL=you@example.com
EMAIL_FROM="Ari BM RSVP <verified-sender@yourdomain.com>"

# Admin modal (nav → Admin). Defaults to 0406 if ADMIN_PIN is unset.
ADMIN_PIN=0406
# Long random string — signs the admin session cookie (required for /api/admin/*).
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
